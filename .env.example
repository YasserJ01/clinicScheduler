# =============================================================================
# Clinic Scheduler — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Secrets (must be set in production):
#   SECRET_KEY        — JWT signing key (generate: python -c "import secrets; print(secrets.token_hex(32))")
#   DB_PASSWORD       — PostgreSQL password
#   REDIS_PASSWORD    — Redis password
#
# Docker Compose dev defaults (docker-compose.yml) are safe for local dev only.
# =============================================================================

# --- Required Secrets ---
# JWT signing key. Minimum 32 chars. Rotate by generating new key; invalidates all active JWTs.
# SECRET_KEY=change-me-in-production

# --- Database ---
# Primary database URL (asyncpg driver)
# DATABASE_URL=postgresql+asyncpg://clinic:clinicpass@localhost:5432/clinic_db
# Read replica URL (optional — defaults to DATABASE_URL if empty)
# READ_DATABASE_URL=
# Connection pool settings
# POOL_SIZE=15
# MAX_OVERFLOW=5

# --- Redis ---
# Redis URL (used for rate limiting, token denylist, metrics)
# REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
# JWT algorithm (default: HS256). Do not change after issuing tokens.
# ALGORITHM=HS256
# Access token lifetime in minutes
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime in days
# REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Application ---
# Log level: debug, info, warning, error
# LOG_LEVEL=info
# CORS allowed origin. Use specific URL in production: https://app.clinic.example.com
# FRONTEND_URL=*
# Enable Alembic migrations instead of create_all (set to true in production)
# ALEMBIC_ENABLED=false
# Enable chaos backdoor (patient_id=999 triggers 503). Do NOT enable in production.
# CHAOS_ENABLED=false

# --- Email (optional) ---
# Provider: null, smtp, or sendgrid
# EMAIL_PROVIDER=null
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SENDGRID_API_KEY=
# FROM_EMAIL=clinic@example.com
